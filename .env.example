# ==================== FLOW RISE API CONFIGURATION ====================

# Server Configuration
NODE_ENV=development
PORT=5000

# Client Configuration (CORS)
CLIENT_URL=http://localhost:3000

# Database Configuration (for future MongoDB integration)
MONGODB_URI=mongodb://localhost:27017/flow-rise
DB_NAME=flow_rise

# Email Configuration (for future email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@flowrise.com

# JWT Configuration (for future authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# API Keys (for future third-party integrations)
STRIPE_API_KEY=your-stripe-api-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# Session Configuration
SESSION_SECRET=your-session-secret-key

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Booking Limits
BOOKING_LIMIT_WINDOW_MS=3600000
BOOKING_LIMIT_MAX=5
